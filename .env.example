# ===========================
# KI-Backend Auswahl
# ===========================
# Cloud-KI nutzen? (true/false)
USE_CLOUD_AI=false

# Ollama (Lokal) - EMPFOHLEN
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=600

# Timeouts für Cloud-APIs (Sekunden)
OPENAI_TIMEOUT=300
ANTHROPIC_TIMEOUT=300

# ===========================
# Cloud-KI API Keys (Optional)
# ===========================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=

# ===========================
# Zero-Knowledge Encryption (KRITISCH!)
# ===========================
# Flask Secret Key (NEVER commit this to git!)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# 
# DEVELOPMENT: Set in .env file (this file is in .gitignore)
# PRODUCTION: Set in systemd service or /etc/environment (NOT in .env!)
#
# WARNING: Changing this will invalidate ALL existing sessions!
FLASK_SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHAR_STRING

# ===========================
# HTTPS & Security Settings
# ===========================
# HTTPS-Enforcement (Flask-Talisman aktivieren)
FORCE_HTTPS=true

# Session-Cookie nur über HTTPS senden (false für Development, true für Production)
SESSION_COOKIE_SECURE=false

# Hinter Reverse Proxy? (nginx, caddy, traefik)
# Aktiviert ProxyFix für X-Forwarded-* Headers
BEHIND_REVERSE_PROXY=false

# ===========================
# Google OAuth (Optional)
# ===========================
# Google Cloud Console: https://console.cloud.google.com
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-your-secret
# GOOGLE_REDIRECT_URI=http://localhost:5000/settings/mail-account/google/callback
