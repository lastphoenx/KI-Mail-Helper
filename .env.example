# ===========================
# KI-Backend Auswahl
# ===========================
# Cloud-KI nutzen? (true/false)
USE_CLOUD_AI=false

# Ollama (Lokal) - EMPFOHLEN
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=600

# Timeouts für Cloud-APIs (Sekunden)
OPENAI_TIMEOUT=300
ANTHROPIC_TIMEOUT=300

# ===========================
# Cloud-KI API Keys (Optional)
# ===========================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=

# ===========================
# Zero-Knowledge Encryption (WICHTIG!)
# ===========================
# Flask Secret Key (generiere mit: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=your-generated-secret-key-here-change-in-production

# ===========================
# HTTPS & Security Settings
# ===========================
# HTTPS-Enforcement (Flask-Talisman aktivieren)
FORCE_HTTPS=true

# Session-Cookie nur über HTTPS senden (false für Development, true für Production)
SESSION_COOKIE_SECURE=false

# Hinter Reverse Proxy? (nginx, caddy, traefik)
# Aktiviert ProxyFix für X-Forwarded-* Headers
BEHIND_REVERSE_PROXY=false

# ===========================
# Google OAuth (Optional)
# ===========================
# Google Cloud Console: https://console.cloud.google.com
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-your-secret
# GOOGLE_REDIRECT_URI=http://localhost:5000/settings/mail-account/google/callback
